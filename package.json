{
  "name": "design-md-ai",
  "version": "5.0.0",
  "description": "Figma to Design.md handoff workspace for AI coding agents.",
  "author": "Stefan Holzheu <design@stefan-holzheu.de>",
  "license": "MIT",
  "homepage": "https://github.com/designready-ai/designready-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/designready-ai/designready-ai.git"
  },
  "bugs": {
    "url": "https://github.com/designready-ai/designready-ai/issues"
  },
  "keywords": [
    "figma",
    "design",
    "ai",
    "ux-audit",
    "design-system",
    "accessibility",
    "wcag"
  ],
  "files": [
    "dist/",
    "shared/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n ui,plugin -c blue,yellow \"npm run dev:ui\" \"npm run dev:plugin\"",
    "dev:web": "vite --config vite.web.config.ts --host 127.0.0.1 --port 5173",
    "web:dev": "vite --config vite.web.config.ts --host 127.0.0.1 --port 5174",
    "web:build": "vite build --config vite.web.config.ts",
    "dev:ui": "vite build --watch",
    "dev:plugin": "esbuild plugin/code.ts --bundle --outfile=dist/code.js --watch --target=es6",
    "build": "npm run build:ui && npm run build:plugin",
    "build:ui": "vite build",
    "build:plugin": "esbuild plugin/code.ts --bundle --outfile=dist/code.js --target=es6",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "typecheck:ui": "tsc --noEmit",
    "typecheck:plugin": "tsc -p tsconfig.plugin.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "format:legacy": "prettier --write .",
    "format:check:legacy": "prettier --check .",
    "package": "npm run build && rm -rf release && mkdir release && cp manifest.json release/ && cp -r dist release/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "lefthook install",
    "turbo:build": "turbo run build",
    "turbo:lint": "turbo run lint",
    "turbo:test": "turbo run test",
    "bench": "npx tsx benchmarks/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@chromatic-com/storybook": "^5.2.1",
    "@figma/plugin-typings": "^1.126.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4-alpha.4",
    "@typescript-eslint/parser": "^8.59.4-alpha.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.0",
    "lefthook": "^2.1.6",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.99.0",
    "storybook": "^10.4.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vite": "8.0.13",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.184",
    "dompurify": "^3.4.4",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.3",
    "marked-highlight": "^2.2.4",
    "openai": "^6.38.0",
    "zod": "^4.4.3"
  }
}
