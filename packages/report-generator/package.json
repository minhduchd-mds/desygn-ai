{
  "name": "@desygn/report-generator",
  "version": "0.1.0",
  "description": "Generate signed PDF / SARIF / CSV / Markdown reports from audit results.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@desygn/audit-engine": "0.1.0",
    "@react-pdf/renderer": "^4.1.6",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@desygn/figma-rest-adapter": "0.1.0",
    "@types/react": "^19.2.15",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
