{
  "name": "@desygn/ui",
  "version": "0.1.0",
  "description": "Shared design system: primitives, patterns, tokens for Desygn A11y apps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./tokens.css": "./src/tokens/tokens.css",
    "./primitives.css": "./src/primitives/primitives.css"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
